# Imganary Configuration
# Copy to .env and customize as needed

# Chat agent (Claude API)
IMGANARY_ANTHROPIC_API_KEY=sk-ant-your-key-here
IMGANARY_CLAUDE_MODEL=claude-sonnet-4-20250514

# Ollama / LLaVA settings
IMGANARY_OLLAMA_BASE_URL=http://localhost:11434
IMGANARY_LLAVA_MODEL_NAME=llava
IMGANARY_LLAVA_TIMEOUT_SECONDS=120

# YOLO settings
IMGANARY_YOLO_MODEL_PATH=yolov8n.pt
IMGANARY_YOLO_CONFIDENCE_THRESHOLD=0.5

# CLIP settings
IMGANARY_CLIP_MODEL_NAME=openai/clip-vit-base-patch32
IMGANARY_CLIP_CANDIDATE_LABELS=["person","animal","vehicle","building","nature","food","text","indoor","outdoor"]

# FLUX.1 image generation
# IMGANARY_FLUX_MODEL_VARIANT=schnell
# IMGANARY_FLUX_DEFAULT_STEPS=4
# IMGANARY_FLUX_QUANTIZATION=
# IMGANARY_FLUX_OUTPUT_DIR=~/Desktop

# General
IMGANARY_LOG_LEVEL=INFO
IMGANARY_MAX_IMAGE_SIZE_MB=20
